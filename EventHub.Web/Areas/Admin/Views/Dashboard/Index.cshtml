@model DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h1 class="mb-4"><i class="bi bi-speedometer2"></i> Dashboard</h1>

<!-- stats cards -->
<div class="row mb-4">
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="card text-white bg-primary">
            <div class="card-body text-center">
                <h3>@Model.TotalEvents</h3>
                <small>Events</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="card text-white bg-success">
            <div class="card-body text-center">
                <h3>@Model.TotalUsers</h3>
                <small>Users</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="card text-white bg-info">
            <div class="card-body text-center">
                <h3>@Model.TotalTicketsSold</h3>
                <small>Tickets Sold</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="card text-white bg-warning">
            <div class="card-body text-center">
                <h3>@Model.TotalCategories</h3>
                <small>Categories</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="card text-white bg-secondary">
            <div class="card-body text-center">
                <h3>@Model.TotalVenues</h3>
                <small>Venues</small>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2 mb-3">
        <div class="card text-white bg-dark">
            <div class="card-body text-center">
                <h3>@Model.TotalRevenue.ToString("C")</h3>
                <small>Revenue</small>
            </div>
        </div>
    </div>
</div>

<!-- recent events table -->
<div class="card">
    <div class="card-header">
        <h5 class="mb-0">Recent Events</h5>
    </div>
    <div class="card-body">
        @if (Model.RecentEvents.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Start Date</th>
                            <th>Available Tickets</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ev in Model.RecentEvents)
                        {
                            <tr>
                                <td>@ev.Id</td>
                                <td>@ev.Title</td>
                                <td>@ev.CategoryName</td>
                                <td>@ev.StartDate.ToString("MMM dd, yyyy")</td>
                                <td>@ev.AvailableTickets</td>
                                <td>
                                    @if (ev.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <a asp-area="" asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id"
                                       class="btn btn-sm btn-outline-primary">View</a>
                                    <a asp-area="" asp-controller="Events" asp-action="Edit" asp-route-id="@ev.Id"
                                       class="btn btn-sm btn-outline-secondary">Edit</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">No events found.</p>
        }
    </div>
</div>
