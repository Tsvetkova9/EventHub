@model IEnumerable<EventItemViewModel>
@{
    ViewData["Title"] = "Manage Events";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-calendar-event"></i> Manage Events</h1>
    <a asp-area="" asp-controller="Events" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> New Event
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Category</th>
                <th>Venue</th>
                <th>Start Date</th>
                <th>Price</th>
                <th>Tickets Left</th>
                <th style="width: 200px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ev in Model)
            {
                <tr>
                    <td>
                        <a asp-area="" asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id">
                            @ev.Title
                        </a>
                    </td>
                    <td>@ev.CategoryName</td>
                    <td>@ev.VenueName, @ev.City</td>
                    <td>@ev.StartDate.ToString("MMM dd, yyyy")</td>
                    <td>@ev.TicketPrice.ToString("C")</td>
                    <td>@ev.AvailableTickets</td>
                    <td>
                        <a asp-area="" asp-controller="Events" asp-action="Edit" asp-route-id="@ev.Id"
                           class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="ToggleEvent" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@ev.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-warning" title="Toggle active status">
                                <i class="bi bi-toggle-on"></i>
                            </button>
                        </form>
                        <form asp-area="" asp-controller="Events" asp-action="Delete" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@ev.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Delete this event?')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<p class="text-muted"><small>Total: @Model.Count() events</small></p>
