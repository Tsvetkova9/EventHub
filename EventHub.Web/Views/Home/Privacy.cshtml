@{
    ViewData["Title"] = "Privacy Policy";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-8">
        <p class="lead">Your privacy is important to us.</p>

        <h4>Data Collection</h4>
        <p>EventHub collects personal information such as your name, email address, and booking history to provide you with our event management services. We do not sell your personal data to third parties.</p>

        <h4>Cookies</h4>
        <p>We use essential cookies to maintain your session and preferences. No tracking cookies are used without your explicit consent.</p>

        <h4>Data Security</h4>
        <p>We use industry-standard encryption and security measures to protect your information. All payment data is processed through secure third-party providers.</p>

        <!-- TODO: get the legal team to review this page before launch -->

        <h4>Contact Us</h4>
        <p>If you have any questions about our privacy practices, please contact us at <strong>privacy@eventhub.com</strong>.</p>

        <p class="text-muted"><small>Last updated: April 2026</small></p>
    </div>
</div>
