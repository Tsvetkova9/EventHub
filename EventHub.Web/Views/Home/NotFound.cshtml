@{
    ViewData["Title"] = "Page Not Found";
}

<div class="text-center" style="margin-top: 80px; margin-bottom: 80px;">
    <h1 class="display-1 text-muted">404</h1>
    <h2>Oops! Page not found</h2>
    <p class="lead text-muted">The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.</p>
    <div style="margin-top: 30px;">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="bi bi-house"></i> Go Home
        </a>
        <a asp-controller="Events" asp-action="Index" class="btn btn-outline-secondary btn-lg ms-2">
            Browse Events
        </a>
    </div>
</div>
