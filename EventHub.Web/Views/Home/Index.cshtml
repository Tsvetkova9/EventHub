@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<style>
    .event-card { transition: transform 0.2s, box-shadow 0.2s; }
    .event-card:hover { transform: translateY(-5px); box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.15) !important; }
    .event-card .card-img-top { height: 200px; object-fit: cover; }
</style>

<!-- hero section -->
<div class="bg-dark bg-gradient text-white rounded-4 p-5 mb-4 shadow" style="margin-top: 15px;">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="display-4 fw-bold">Discover Amazing Events</h1>
            <p class="lead text-white-50">Find and book tickets for concerts, conferences, sports, and more. Your next great experience is just a click away.</p>
            <a asp-controller="Events" asp-action="Index" class="btn btn-light btn-lg fw-semibold">
                <i class="bi bi-search"></i> Browse Events
            </a>
        </div>
        <div class="col-md-4 text-center d-none d-md-block">
            <i class="bi bi-calendar-event" style="font-size: 8rem; opacity: 0.15;"></i>
        </div>
    </div>
</div>

<!-- stats row -->
<div class="row text-center mb-5">
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body py-4">
                <h1 class="fw-bold text-primary mb-1">@Model.TotalEvents</h1>
                <p class="text-muted mb-0 small text-uppercase fw-semibold">Active Events</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body py-4">
                <h1 class="fw-bold text-primary mb-1">@Model.TotalCategories</h1>
                <p class="text-muted mb-0 small text-uppercase fw-semibold">Categories</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body py-4">
                <h1 class="fw-bold text-primary mb-1">@Model.TotalVenues</h1>
                <p class="text-muted mb-0 small text-uppercase fw-semibold">Venues</p>
            </div>
        </div>
    </div>
</div>

<!-- upcoming events -->
<h2 class="mb-3">Upcoming Events</h2>
<div class="row">
    @if (Model.UpcomingEvents.Any())
    {
        @foreach (var ev in Model.UpcomingEvents)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0 shadow-sm rounded-3 event-card">
                    @if (!string.IsNullOrEmpty(ev.ImageUrl))
                    {
                        <img src="@ev.ImageUrl" class="card-img-top" alt="@ev.Title" />
                    }
                    else
                    {
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center card-img-top">
                            <i class="bi bi-image" style="font-size: 3rem;"></i>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-primary-subtle text-primary mb-2" style="width: fit-content;">@ev.CategoryName</span>
                        <h5 class="card-title fw-semibold">@ev.Title</h5>
                        <p class="card-text text-muted small">
                            <i class="bi bi-calendar"></i> @ev.StartDate.ToString("MMM dd, yyyy") &nbsp;
                            <i class="bi bi-geo-alt"></i> @ev.VenueName, @ev.City
                        </p>
                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-success fs-5">@ev.TicketPrice.ToString("C")</span>
                            <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="btn btn-primary btn-sm">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info">No upcoming events at the moment. Check back soon!</div>
        </div>
    }
</div>

<div class="text-center mt-3">
    <a asp-controller="Events" asp-action="Index" class="btn btn-primary">
        View All Events <i class="bi bi-arrow-right"></i>
    </a>
</div>
