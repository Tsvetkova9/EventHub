@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<!-- hero section -->
<div class="bg-primary text-white rounded-3 p-5 mb-4" style="margin-top: 15px;">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="display-4 fw-bold">Discover Amazing Events</h1>
            <p class="lead">Find and book tickets for concerts, conferences, sports, and more. Your next great experience is just a click away.</p>
            <a asp-controller="Events" asp-action="Index" class="btn btn-light btn-lg">
                <i class="bi bi-search"></i> Browse Events
            </a>
        </div>
        <div class="col-md-4 text-center d-none d-md-block">
            <i class="bi bi-calendar-event" style="font-size: 8rem; opacity: 0.3;"></i>
        </div>
    </div>
</div>

<!-- stats row -->
<div class="row text-center mb-5">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h2 class="text-primary">@Model.TotalEvents</h2>
                <p class="text-muted">Active Events</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h2 class="text-primary">@Model.TotalCategories</h2>
                <p class="text-muted">Categories</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h2 class="text-primary">@Model.TotalVenues</h2>
                <p class="text-muted">Venues</p>
            </div>
        </div>
    </div>
</div>

<!-- upcoming events -->
<h2 class="mb-3">Upcoming Events</h2>
<div class="row">
    @if (Model.UpcomingEvents.Any())
    {
        @foreach (var ev in Model.UpcomingEvents)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(ev.ImageUrl))
                    {
                        <img src="@ev.ImageUrl" class="card-img-top" alt="@ev.Title" style="height: 200px; object-fit: cover;" />
                    }
                    else
                    {
                        <!-- placeholder if no image -->
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 200px;">
                            <i class="bi bi-image" style="font-size: 3rem;"></i>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title">@ev.Title</h5>
                        <p class="card-text text-muted">
                            <i class="bi bi-calendar"></i> @ev.StartDate.ToString("MMM dd, yyyy") <br />
                            <i class="bi bi-geo-alt"></i> @ev.VenueName, @ev.City <br />
                            <i class="bi bi-tag"></i> @ev.CategoryName
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-success">@ev.TicketPrice.ToString("C")</span>
                            <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id" class="btn btn-outline-primary btn-sm">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info">No upcoming events at the moment. Check back soon!</div>
        </div>
    }
</div>

<div class="text-center mt-3">
    <a asp-controller="Events" asp-action="Index" class="btn btn-primary">
        View All Events <i class="bi bi-arrow-right"></i>
    </a>
</div>
