@model EventDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<nav aria-label="breadcrumb" style="margin-top: 10px;">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-controller="Events" asp-action="Index">Events</a></li>
        <li class="breadcrumb-item active">@Model.Title</li>
    </ol>
</nav>

<div class="row">
    <!-- left column - event info -->
    <div class="col-md-8">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="img-fluid rounded mb-3" alt="@Model.Title" style="max-height: 400px; width: 100%; object-fit: cover;" />
        }

        <h1>@Model.Title</h1>

        @if (!Model.IsActive)
        {
            <div class="alert alert-warning">
                <i class="bi bi-exclamation-triangle"></i> This event is no longer active.
            </div>
        }

        <p class="lead">@Model.Description</p>

        <!-- reviews section -->
        <hr />
        <h3>
            Reviews
            @if (Model.AverageRating > 0)
            {
                <small class="text-muted">
                    (@Model.AverageRating.ToString("F1") / 5.0 -
                    @Model.Reviews.Count() review@(Model.Reviews.Count() != 1 ? "s" : ""))
                </small>
            }
        </h3>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <button class="btn btn-outline-primary btn-sm mb-3" type="button"
                    data-bs-toggle="collapse" data-bs-target="#reviewForm" aria-expanded="false">
                <i class="bi bi-pencil"></i> Write a Review
            </button>

            <div class="collapse mb-3" id="reviewForm">
                <div class="card card-body border-0 bg-light">
                    <h6>Your Review</h6>
                    <form id="ajaxReviewForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="EventId" value="@Model.Id" />
                        <input type="hidden" name="EventTitle" value="@Model.Title" />
                        <div class="mb-2">
                            <label class="form-label small">Rating</label>
                            <select name="Rating" class="form-select form-select-sm w-auto" required>
                                <option value="">— pick —</option>
                                <option value="5">★★★★★ (5)</option>
                                <option value="4">★★★★☆ (4)</option>
                                <option value="3">★★★☆☆ (3)</option>
                                <option value="2">★★☆☆☆ (2)</option>
                                <option value="1">★☆☆☆☆ (1)</option>
                            </select>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small">Comment</label>
                            <textarea name="Content" class="form-control form-control-sm" rows="3"
                                      maxlength="1000" placeholder="Share your experience..." required></textarea>
                        </div>
                        <div id="reviewError" class="text-danger small mb-2" style="display:none;"></div>
                        <button type="submit" class="btn btn-primary btn-sm">Submit Review</button>
                    </form>
                </div>
            </div>
        }

        <div id="reviews-list">
        @if (Model.Reviews.Any())
        {
            @foreach (var review in Model.Reviews)
            {
                <div class="card mb-2">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <strong>@review.UserName</strong>
                            <small class="text-muted">@review.CreatedOn.ToString("MMM dd, yyyy")</small>
                        </div>
                        <div class="mb-1">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= review.Rating)
                                {
                                    <i class="bi bi-star-fill text-warning"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star text-warning"></i>
                                }
                            }
                        </div>
                        <p class="mb-1">@review.Content</p>
                        @if (User.Identity?.IsAuthenticated == true && review.UserId == @User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                        {
                            <form asp-controller="Reviews" asp-action="Delete" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@review.Id" />
                                <input type="hidden" name="eventId" value="@Model.Id" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Delete this review?')">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted" id="no-reviews-msg">No reviews yet. Be the first to share your thoughts!</p>
        }
        </div>

<script>
(function () {
    const form = document.getElementById('ajaxReviewForm');
    if (!form) return;

    form.addEventListener('submit', async function (e) {
        e.preventDefault();

        const token = form.querySelector('[name="__RequestVerificationToken"]').value;
        const payload = {
            EventId: parseInt(form.querySelector('[name="EventId"]').value),
            EventTitle: form.querySelector('[name="EventTitle"]').value,
            Rating: parseInt(form.querySelector('[name="Rating"]').value),
            Content: form.querySelector('[name="Content"]').value
        };

        const errBox = document.getElementById('reviewError');
        errBox.style.display = 'none';

        try {
            const res = await fetch('/Reviews/CreateAjax', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify(payload)
            });

            if (!res.ok) {
                const err = await res.json();
                errBox.textContent = (err.errors || ['An error occurred.']).join(' ');
                errBox.style.display = '';
                return;
            }

            const data = await res.json();
            if (!data.success) {
                errBox.textContent = 'Could not submit review.';
                errBox.style.display = '';
                return;
            }

            // build rating stars html
            let stars = '';
            for (let i = 1; i <= 5; i++) {
                stars += i <= data.review.rating
                    ? '<i class="bi bi-star-fill text-warning"></i>'
                    : '<i class="bi bi-star text-warning"></i>';
            }

            const card = `
                <div class="card mb-2">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <strong>${data.review.userName}</strong>
                            <small class="text-muted">${data.review.createdOn}</small>
                        </div>
                        <div class="mb-1">${stars}</div>
                        <p class="mb-1">${data.review.content}</p>
                    </div>
                </div>`;

            const noMsg = document.getElementById('no-reviews-msg');
            if (noMsg) noMsg.remove();

            document.getElementById('reviews-list').insertAdjacentHTML('afterbegin', card);

            // collapse form and reset
            bootstrap.Collapse.getOrCreateInstance(document.getElementById('reviewForm')).hide();
            form.reset();
        } catch (ex) {
            errBox.textContent = 'Network error. Please try again.';
            errBox.style.display = '';
        }
    });
})();
</script>
    </div>

    <!-- right column - sidebar -->
    <div class="col-md-4">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Event Details</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled">
                    <li class="mb-2">
                        <i class="bi bi-calendar-event text-primary"></i>
                        <strong>Start:</strong> @Model.StartDate.ToString("MMM dd, yyyy h:mm tt")
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-calendar-check text-primary"></i>
                        <strong>End:</strong> @Model.EndDate.ToString("MMM dd, yyyy h:mm tt")
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-geo-alt text-primary"></i>
                        <strong>Venue:</strong> @Model.VenueName
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-signpost text-primary"></i>
                        <strong>Address:</strong> @Model.VenueAddress, @Model.City
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-tag text-primary"></i>
                        <strong>Category:</strong> @Model.CategoryName
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-person text-primary"></i>
                        <strong>Organizer:</strong> @Model.OrganizerName
                    </li>
                    <li class="mb-2">
                        <i class="bi bi-ticket-perforated text-primary"></i>
                        <strong>Available:</strong> @Model.AvailableTickets tickets
                    </li>
                </ul>

                <hr />

                <div class="text-center">
                    <h3 class="text-success">@Model.TicketPrice.ToString("C")</h3>

                    @if (Model.IsActive && Model.AvailableTickets > 0 && Model.StartDate > DateTime.UtcNow)
                    {
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Tickets" asp-action="Purchase" asp-route-eventId="@Model.Id"
                               class="btn btn-success btn-lg w-100">
                                <i class="bi bi-cart-plus"></i> Buy Tickets
                            </a>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-primary btn-lg w-100">
                                Login to Buy
                            </a>
                        }
                    }
                    else if (Model.AvailableTickets == 0)
                    {
                        <button class="btn btn-secondary btn-lg w-100" disabled>Sold Out</button>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-lg w-100" disabled>Not Available</button>
                    }
                </div>
            </div>
        </div>

        <!-- organizer actions -->
        @if (User.Identity?.IsAuthenticated == true)
        {
            var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (currentUserId == Model.OrganizerName || User.IsInRole("Admin"))
            {
                <!-- only show edit/delete if user is organizer or admin -->
            }
        }
        @if (User.IsInRole("Admin"))
        {
            <div class="card shadow-sm">
                <div class="card-header bg-warning">
                    <h6 class="mb-0">Admin Actions</h6>
                </div>
                <div class="card-body">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary w-100 mb-2">
                        <i class="bi bi-pencil"></i> Edit Event
                    </a>
                    <form asp-action="Delete" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('Are you sure you want to delete this event?')">
                            <i class="bi bi-trash"></i> Delete Event
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
