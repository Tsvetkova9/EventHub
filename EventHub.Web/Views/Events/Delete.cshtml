@model EventItemViewModel
@{
    ViewData["Title"] = "Delete Event";
}

<h1 class="text-danger"><i class="bi bi-trash"></i> Delete Event</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="alert alert-danger">
            <strong>Are you sure you want to delete this event?</strong>
            <p class="mb-0 mt-1">This action cannot be undone.</p>
        </div>

        <div class="card mb-4">
            <div class="card-body">
                <h4>@Model.Title</h4>
                <p class="text-muted">@Model.Description</p>
                <ul class="list-unstyled">
                    <li><i class="bi bi-calendar"></i> @Model.StartDate.ToString("MMMM dd, yyyy")</li>
                    <li><i class="bi bi-geo-alt"></i> @Model.VenueName, @Model.City</li>
                    <li><i class="bi bi-tag"></i> @Model.CategoryName</li>
                    <li><i class="bi bi-currency-dollar"></i> @Model.TicketPrice.ToString("C") per ticket</li>
                    <li><i class="bi bi-ticket"></i> @Model.AvailableTickets tickets remaining</li>
                </ul>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash"></i> Yes, Delete Event
            </button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary ms-2">
                <i class="bi bi-arrow-left"></i> Cancel
            </a>
        </form>
    </div>
</div>
