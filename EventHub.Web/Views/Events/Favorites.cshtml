@model IEnumerable<EventItemViewModel>
@{
    ViewData["Title"] = "My Favorites";
}

<style>
    .event-card { transition: transform 0.2s, box-shadow 0.2s; }
    .event-card:hover { transform: translateY(-5px); box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.15) !important; }
    .event-card .card-img-top { height: 200px; object-fit: cover; }
</style>

<div class="d-flex align-items-center mb-4">
    <h1 class="me-auto mb-0"><i class="bi bi-heart-fill text-danger"></i> My Favorites</h1>
    <a asp-controller="Events" asp-action="Index" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-search"></i> Browse Events
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-heart text-muted" style="font-size: 4rem;"></i>
        <h4 class="mt-3 text-muted">You haven't saved any events yet.</h4>
        <p class="text-muted">Browse events and click the <i class="bi bi-heart"></i> icon to save your favourites here.</p>
        <a asp-controller="Events" asp-action="Index" class="btn btn-primary mt-2">
            <i class="bi bi-search"></i> Browse Events
        </a>
    </div>
}
else
{
    <p class="text-muted mb-3">@Model.Count() saved event@(Model.Count() != 1 ? "s" : "")</p>

    <div class="row">
        @foreach (var ev in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0 shadow-sm rounded-3 event-card">
                    @if (!string.IsNullOrEmpty(ev.ImageUrl))
                    {
                        <img src="@ev.ImageUrl" class="card-img-top" alt="@ev.Title" />
                    }
                    else
                    {
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center card-img-top">
                            <i class="bi bi-image" style="font-size: 3rem;"></i>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-primary-subtle text-primary mb-2" style="width: fit-content;">@ev.CategoryName</span>
                        <h5 class="card-title fw-semibold">@ev.Title</h5>
                        <p class="card-text text-muted small">@ev.Description</p>
                        <div class="mt-auto">
                            <p class="mb-1 small"><i class="bi bi-calendar"></i> @ev.StartDate.ToString("MMM dd, yyyy")</p>
                            <p class="mb-2 small"><i class="bi bi-geo-alt"></i> @ev.VenueName, @ev.City</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-success fs-5">@ev.TicketPrice.ToString("C")</span>
                                <div class="d-flex gap-2 align-items-center">
                                    <button class="btn btn-sm btn-link p-0 favorite-btn"
                                            data-event-id="@ev.Id"
                                            title="Remove from favorites">
                                        <i class="bi bi-heart-fill text-danger fs-5"></i>
                                    </button>
                                    <a asp-controller="Events" asp-action="Details" asp-route-id="@ev.Id"
                                       class="btn btn-primary btn-sm">Details</a>
                                </div>
                            </div>
                            @if (ev.AvailableTickets == 0)
                            {
                                <span class="badge bg-danger mt-2">Sold Out</span>
                            }
                            else if (ev.AvailableTickets < 20)
                            {
                                <span class="badge bg-warning text-dark mt-2">Only @ev.AvailableTickets left!</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@Html.AntiForgeryToken()
<script>
(function () {
    const token = document.querySelector('[name="__RequestVerificationToken"]')?.value;

    document.querySelectorAll('.favorite-btn').forEach(btn => {
        btn.addEventListener('click', async function () {
            const eventId = this.dataset.eventId;
            const card = this.closest('.col-md-4');

            try {
                const res = await fetch('/Events/ToggleFavorite', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: `id=${eventId}`
                });

                if (!res.ok) return;
                const data = await res.json();

                // if removed from favorites, fade out and remove the card
                if (!data.isFavorited && card) {
                    card.style.transition = 'opacity 0.3s';
                    card.style.opacity = '0';
                    setTimeout(() => {
                        card.remove();
                        // show empty state if no cards left
                        const remaining = document.querySelectorAll('.favorite-btn').length;
                        if (remaining === 0) location.reload();
                    }, 300);
                }
            } catch { /* silent fail */ }
        });
    });
})();
</script>
