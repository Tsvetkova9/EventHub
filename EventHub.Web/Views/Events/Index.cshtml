@model EventListViewModel
@{
    ViewData["Title"] = "Events";
}

<h1 class="mb-4">Browse Events</h1>

<!-- search and filter -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row g-3">
                <div class="col-md-6">
                    <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control"
                           placeholder="Search events by title, description or city..." />
                </div>
                <div class="col-md-4">
                    <select name="categoryId" class="form-select">
                        <option value="">All Categories</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Search
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<p class="text-muted">Showing @Model.Events.Count() of @Model.TotalCount events</p>

<!-- event cards -->
<div class="row">
    @if (Model.Events.Any())
    {
        @foreach (var ev in Model.Events)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(ev.ImageUrl))
                    {
                        <img src="@ev.ImageUrl" class="card-img-top" alt="@ev.Title" style="height: 200px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 200px;">
                            <i class="bi bi-image" style="font-size: 3rem;"></i>
                        </div>
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@ev.Title</h5>
                        <p class="card-text text-muted small">@ev.Description</p>
                        <div class="mt-auto">
                            <p class="mb-1"><i class="bi bi-calendar"></i> @ev.StartDate.ToString("MMM dd, yyyy")</p>
                            <p class="mb-1"><i class="bi bi-geo-alt"></i> @ev.VenueName, @ev.City</p>
                            <p class="mb-2"><i class="bi bi-tag"></i> @ev.CategoryName</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-success fs-5">@ev.TicketPrice.ToString("C")</span>
                                <a asp-action="Details" asp-route-id="@ev.Id" class="btn btn-primary btn-sm">Details</a>
                            </div>
                            @if (ev.AvailableTickets == 0)
                            {
                                <span class="badge bg-danger mt-2">Sold Out</span>
                            }
                            else if (ev.AvailableTickets < 20)
                            {
                                <span class="badge bg-warning mt-2">Only @ev.AvailableTickets left!</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> No events found matching your criteria. Try a different search.
            </div>
        </div>
    }
</div>

<!-- pagination -->
@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)"
                   asp-route-searchTerm="@Model.SearchTerm" asp-route-categoryId="@Model.CategoryId">
                    Previous
                </a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                       asp-route-searchTerm="@Model.SearchTerm" asp-route-categoryId="@Model.CategoryId">
                        @i
                    </a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)"
                   asp-route-searchTerm="@Model.SearchTerm" asp-route-categoryId="@Model.CategoryId">
                    Next
                </a>
            </li>
        </ul>
    </nav>
}
