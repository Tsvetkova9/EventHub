@{
    ViewData["Title"] = "Purchase Successful";
}

<div class="text-center" style="margin-top: 60px; margin-bottom: 60px;">
    <div style="font-size: 5rem; color: #198754;">
        <i class="bi bi-check-circle-fill"></i>
    </div>
    <h1 class="mt-3">Thank You for Your Purchase!</h1>
    <p class="lead text-muted">Your ticket order has been confirmed. We hope you enjoy the event!</p>
    <hr class="w-25 mx-auto" />
    <div style="margin-top: 30px;">
        <a asp-action="MyTickets" class="btn btn-success btn-lg">
            <i class="bi bi-ticket-perforated"></i> View My Tickets
        </a>
        <a asp-controller="Events" asp-action="Index" class="btn btn-outline-secondary btn-lg ms-2">
            <i class="bi bi-search"></i> Browse More Events
        </a>
    </div>
</div>
