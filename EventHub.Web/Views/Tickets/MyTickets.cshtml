@model TicketListViewModel
@{
    ViewData["Title"] = "My Tickets";
}

<h1><i class="bi bi-ticket-perforated"></i> My Tickets</h1>
<hr />

@if (Model.Tickets.Any())
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Event</th>
                    <th>Venue</th>
                    <th>Event Date</th>
                    <th>Qty</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Purchased</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in Model.Tickets)
                {
                    <tr>
                        <td>@ticket.EventTitle</td>
                        <td>@ticket.VenueName</td>
                        <td>@ticket.EventDate.ToString("MMM dd, yyyy")</td>
                        <td>@ticket.Quantity</td>
                        <td>@ticket.TotalPrice.ToString("C")</td>
                        <td>
                            @if (ticket.Status == "Active")
                            {
                                <span class="badge bg-success">@ticket.Status</span>
                            }
                            else if (ticket.Status == "Cancelled")
                            {
                                <span class="badge bg-danger">@ticket.Status</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@ticket.Status</span>
                            }
                        </td>
                        <td>@ticket.PurchasedOn.ToString("MMM dd, yyyy")</td>
                        <td>
                            @if (ticket.Status == "Active")
                            {
                                <form asp-action="Cancel" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@ticket.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm"
                                            onclick="return confirm('Are you sure you want to cancel this ticket?')">
                                        Cancel
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-ticket-perforated" style="font-size: 4rem; color: #ccc;"></i>
        <h3 class="text-muted mt-3">No tickets yet</h3>
        <p class="text-muted">Browse events and book your first ticket!</p>
        <a asp-controller="Events" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-search"></i> Find Events
        </a>
    </div>
}
