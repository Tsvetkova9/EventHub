@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center" style="margin-top: 80px; margin-bottom: 80px;">
    <h1 class="display-1 text-danger">500</h1>
    <h2>Something went wrong</h2>
    <p class="lead text-muted">An unexpected error occurred. Please try again later or contact support if the problem persists.</p>

    @if (Model?.ShowRequestId ?? false)
    {
        <p class="text-muted"><small>Request ID: @Model!.RequestId</small></p>
    }

    <div style="margin-top: 30px;">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
            <i class="bi bi-house"></i> Go Home
        </a>
    </div>
</div>
