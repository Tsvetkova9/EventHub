@using Microsoft.AspNetCore.Identity
@inject SignInManager<EventHub.Core.Entities.ApplicationUser> SignInManager
@inject UserManager<EventHub.Core.Entities.ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <span class="nav-link text-light">Hello, @UserManager.GetUserName(User)!</span>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-controller="Events" asp-action="Create">
            <i class="bi bi-plus-circle"></i> Create Event
        </a>
    </li>
    <li class="nav-item">
        <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
            <button type="submit" class="nav-link btn btn-link text-light">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
    <li class="nav-item">
        <!-- changed from nav-link to btn, the link was too small and hard to see -->
        <a class="btn btn-outline-light btn-sm ms-2" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
}
</ul>
